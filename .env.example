# Exempelfil för miljövariabler.
# Kopiera denna fil och döp kopian till .env
#
# Så här får du en IPinfo API-token:
# 1. Gå till https://ipinfo.io/
# 2. Skapa ett konto eller logga in
# 3. Gå till dashboarden
# 4. Leta upp sektionen "API Access"
# 5. Kopiera din API Token
# 6. Klistra in token efter IPINFO_TOKEN=
#
# Den riktiga .env-filen ska inte laddas upp till GitHub.
# Därför finns .env med i .gitignore.

IPINFO_TOKEN=api_token_here